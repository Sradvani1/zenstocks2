rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isValidSymbol(s) {
      return s.matches('^[A-Z][A-Z0-9.-]{0,9}$');
    }

    function isInUniverse(symbol) {
      return exists(/databases/$(database)/documents/symbols/universe/entries/$(symbol));
    }

    function isValidHolding(data, symbolId) {
      return data.keys().hasOnly(['symbol', 'shares', 'createdAt', 'updatedAt'])
        && data.symbol == symbolId
        && isValidSymbol(data.symbol)
        && data.shares is int
        && data.shares >= 1
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /holdings/{symbol} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidHolding(request.resource.data, symbol)
          && isInUniverse(symbol)
          && !exists(/databases/$(database)/documents/users/$(uid)/holdings/$(symbol));
        allow update: if isOwner(uid)
          && isValidHolding(request.resource.data, symbol)
          && isInUniverse(symbol)
          && request.resource.data.symbol == resource.data.symbol
          && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(uid);
      }
    }

    match /symbols/universe/entries/{symbol} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /quotes/{symbol} {
      allow read: if request.auth != null;
      allow write: if false;

      match /history/{date} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /fundamentals/{docId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /articles/{symbol}/entries/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /symbols/active/{symbol} {
      allow read, write: if false;
    }

    match /pipelineRuns/{runId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
